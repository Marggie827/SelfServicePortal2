@inherits LayoutComponentBase
@using SelfServicePortal.Components.Pages.Auth
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

q<MudDialogProvider />
<MudSnackbarProvider />
<MudThemeProvider Theme="_theme" />
<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-3">
            Self-Service Portal
        </MudText>
        <MudSpacer />
        <NotificationBell />
        <MudIconButton Icon="@Icons.Material.Filled.Logout"
                       Color="Color.Inherit"
                       OnClick="@Logout" />
    </MudAppBar>

    <MudDrawer @bind-Open="@_drawerOpen" Elevation="2">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">Menu</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/dashboard"
                        Icon="@Icons.Material.Filled.Dashboard">
                Dashboard
            </MudNavLink>
            <MudNavLink Href="/requests/list"
                        Icon="@Icons.Material.Filled.List">
                My Requests
            </MudNavLink>
            <MudNavLink Href="/requests/create"
                        Icon="@Icons.Material.Filled.Add">
                New Request
            </MudNavLink>
            <AuthorizeView Roles="Admin">
                <Authorized>
                    <MudDivider Class="my-2" />
                    <MudNavLink Href="/admin"
                                Icon="@Icons.Material.Filled.AdminPanelSettings">
                        Admin Panel
                    </MudNavLink>
                </Authorized>
            </AuthorizeView>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    MudTheme _theme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#1976D2",
            Secondary = "#424242",
            AppbarBackground = "blue",
            Background = "purple"
        }
    };

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task Logout()
    {
        if (AuthStateProvider is CustomAuthStateProvider authProvider)
        {
            await authProvider.LogoutAsync();
        }
        Navigation.NavigateTo("/auth/login", forceLoad: true);
    }
}